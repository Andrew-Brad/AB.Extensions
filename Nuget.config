<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <!-- Pin to a single source for Central Package Management; clear machine-wide ones. -->
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    </packageSources>
</configuration>
