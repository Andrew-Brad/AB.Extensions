<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <!-- Clear machine-wide sources so restore is reproducible from this repo alone. -->
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
        <!-- Local feed for dogfooding our own package before it's published.
             Populated by scripts/pack-local.ps1; contents are git-ignored. -->
        <add key="local" value="feed" />
    </packageSources>

    <!-- With more than one source, package source mapping is the modern way to keep
         restore unambiguous (and it's what silences NU1507). Everything resolves from
         nuget.org; AB.Extensions may *also* come from the local feed, so a locally
         packed dev build is consumed when present and nuget.org is the fallback. -->
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
            <package pattern="AB.Extensions" />
        </packageSource>
        <packageSource key="local">
            <package pattern="AB.Extensions" />
        </packageSource>
    </packageSourceMapping>
</configuration>
